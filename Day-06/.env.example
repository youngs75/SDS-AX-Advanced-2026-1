# =============================================================================
# Day-06 RunPod 환경 설정 파일
# =============================================================================
#
# 사용법:
#   1. 이 파일을 복사하여 .env 로 저장하세요:
#      cp .env.example .env
#   2. 아래 값들을 실제 키로 채우세요.
#   3. setup_runpod.sh 를 실행하면 자동으로 .env 를 읽습니다.
#
# 주의: .env 파일에는 민감한 키가 포함됩니다.
#       절대 git에 커밋하지 마세요. (.gitignore에 추가 권장)
# =============================================================================

# ---------------------------------------------------------------------------
# [필수] RunPod API Key
# ---------------------------------------------------------------------------
# 발급 방법:
#   1. https://www.runpod.io/console/user/settings 접속
#   2. 좌측 메뉴에서 "API Keys" 클릭
#   3. "Create API Key" 버튼 클릭
#   4. 키 이름 입력 (예: "day06-workshop") → "Create" 클릭
#   5. 생성된 키를 복사 (한 번만 표시되므로 반드시 저장)
#
# RunPod 계정이 없으면:
#   https://www.runpod.io/console/signup 에서 가입
#   가입 후 크레딧 충전: https://www.runpod.io/console/user/billing
#   (최소 $10 충전 권장 — 24GB GPU 기준 시간당 $0.4~$1.0)
# ---------------------------------------------------------------------------
RUNPOD_API_KEY=

# ---------------------------------------------------------------------------
# [권장] HuggingFace Access Token
# ---------------------------------------------------------------------------
# 발급 방법:
#   1. https://huggingface.co/settings/tokens 접속
#   2. HuggingFace 계정 로그인 (없으면 https://huggingface.co/join 에서 가입)
#   3. "Create new token" 클릭
#   4. Token name 입력 (예: "day06-workshop")
#   5. Type: "Read" 선택 (모델 다운로드만 필요)
#   6. "Create token" 클릭 → 생성된 "hf_..." 토큰 복사
#
# 이 토큰이 없으면:
#   - 공개 모델(Qwen3.5, Qwen3-Embedding)은 다운로드 가능
#   - 단, rate limit에 걸릴 수 있고 일부 gated model은 접근 불가
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# [선택] OpenAI API Key — Lab 0 합성 데이터 생성에 필요
# ---------------------------------------------------------------------------
# 발급 방법:
#   1. https://platform.openai.com/api-keys 접속
#   2. OpenAI 계정 로그인 (없으면 https://platform.openai.com/signup 에서 가입)
#   3. "+ Create new secret key" 클릭
#   4. 키 이름 입력 (예: "day06-workshop") → "Create secret key" 클릭
#   5. 생성된 "sk-..." 키를 복사 (한 번만 표시됨)
#
# 크레딧 확인:
#   https://platform.openai.com/settings/organization/billing/overview
#   Lab 0에서 gpt-5.4-mini 사용 시 약 $0.5~$2.0 예상
#
# 이 키가 없으면:
#   - Lab 0 합성 데이터 생성을 건너뜁니다
#   - 대신 폴백 데이터셋(data/sft_train_fallback.jsonl 등)으로 Lab 1/2 진행 가능
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# [선택] Pod 설정 커스터마이징
# ---------------------------------------------------------------------------
# 기본값을 변경하고 싶으면 아래 주석을 해제하세요.
# GPU_ID="NVIDIA GeForce RTX 4090"       # 기본: 자동 선택 (4090 > L4 > A5000 > 3090)
# VOLUME_GB=50                            # 영속 볼륨 크기 (GB)
# CONTAINER_DISK_GB=30                    # 컨테이너 디스크 크기 (GB)
# CLOUD_TYPE=SECURE                       # SECURE 또는 COMMUNITY
# DOCKER_IMAGE=runpod/pytorch:1.0.3-cu1281-torch291-ubuntu2404
