# Day-08 LiteLLM example environment
# Copy this file to .env before running docker compose.

# LiteLLM learner-facing gateway key
LITELLM_MASTER_KEY=sk-day08-litellm

# Upstream vLLM OpenAI-compatible endpoint. Include /v1.
VLLM_API_BASE=http://host.docker.internal:8000/v1

# Upstream vLLM API key. If your vLLM server does not enforce auth,
# keep a non-empty placeholder so the config stays simple.
VLLM_API_KEY=vllm-demo-key

# Full LiteLLM provider/model string pointing to the upstream vLLM model
VLLM_LITELLM_MODEL=openai/Qwen/Qwen3.5-9B

# Alias exposed by LiteLLM to notebooks and apps
LITELLM_MODEL_ALIAS=day08-vllm

# LiteLLM internal Postgres password
POSTGRES_PASSWORD=dbpassword9090
