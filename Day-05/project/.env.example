# ---------- OpenRouter (모든 LLM 호출의 단일 게이트웨이) ----------
# 절대 노출되지 않도록 주의해주세요.
# 수업/과제 외 타 용도로 사용을 절대 금지하며, 모든 호출 기록이 모니터링 되고 있음을 알려드립니다.
# 이 API Key 의 사용 기간은 2026.02.21 12:30:00 - 2026.02.22 23:59:00 까지입니다.
OPENROUTER_API_KEY=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
OPENROUTER_MODEL_NAME=openai/gpt-5

# ---------- Langfuse ----------
# LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse SDK controls
LANGFUSE_TRACING_ENABLED=1
LANGFUSE_OBSERVE_DECORATOR_IO_CAPTURE_ENABLED=0
LANGFUSE_SAMPLE_RATE=1.0

# ---------- Trace / Ops tags ----------
ENV=local
SERVICE_NAME=agent-ops-day3
APP_VERSION=0.1.0

# ---------- Data paths ----------
DATA_DIR=./data
LOCAL_CORPUS_DIR=./data/corpus

# ---------- DeepEval ----------
# DeepEval은 OPENROUTER_API_KEY, OPENROUTER_MODEL_NAME 환경변수를 자동으로 읽음
