# ── OpenRouter (LLM 단일 게이트웨이) ──
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_NAME=openai/gpt-5.4

# ── OpenAI (직접 호출) ──
OPENAI_API_KEY=

# ── Document AI ──
UPSTAGE_API_KEY=
LLAMA_CLOUD_API_KEY=
HF_TOKEN=

# ── Neo4j ──
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── LangSmith ──
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=LangGraph-Tutorial

# ── Tavily ──
TAVILY_API_KEY=

# ── Langfuse (관측성) ──
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_TRACING_ENABLED=1
LANGFUSE_OBSERVE_DECORATOR_IO_CAPTURE_ENABLED=0
LANGFUSE_SAMPLE_RATE=1.0

# ── Application ──
ENV=local
SERVICE_NAME=youngs75-a2a
APP_VERSION=0.1.0
DATA_DIR=./youngs75_a2a/data
LOCAL_CORPUS_DIR=./youngs75_a2a/data/corpus
